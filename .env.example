NODE_ENV=production
API_PORT=3000
API_BASE_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
LOG_LEVEL=info

POSTGRES_DB=url_shortener
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
API_DATABASE_URL=postgresql://postgres:postgres@db:5432/url_shortener
WORKER_DATABASE_URL=postgresql://postgres:postgres@db:5432/url_shortener

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379
REDIS_CACHE_TTL_SECONDS=86400
REDIS_STREAM_NAME=clicks
REDIS_STREAM_MAXLEN=1000000
REDIS_CONSUMER_GROUP=analytics-workers
REDIS_CONSUMER_NAME=worker-1
REDIS_BLOCK_MS=5000
REDIS_BATCH_SIZE=200
REDIS_CLAIM_IDLE_MS=60000
REDIS_CLAIM_BATCH_SIZE=100

SNOWFLAKE_NODE_ID=1
SNOWFLAKE_EPOCH=1704067200000
HASH_SALT=change-this-salt
HASH_CODE_LENGTH=8
MAX_SHORT_CODE_RETRIES=8

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300

FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:3000
